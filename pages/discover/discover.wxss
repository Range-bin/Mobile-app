.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.search-section {
  margin-bottom: 20rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 40rpx;
  padding: 16rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 20rpx;
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.clear-icon {
  width: 32rpx;
  height: 32rpx;
  margin-left: 16rpx;
}

.filter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.category-scroll {
  white-space: nowrap;
  flex: 1;
  margin-right: 20rpx;
}

.category-tag {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666666;
  background-color: #f5f5f5;
  transition: all 0.3s ease;
}

.category-tag.active {
  color: #ffffff;
  background-color: #ff6b35;
  font-weight: bold;
}

.sort-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 30rpx;
}

.sort-text {
  font-size: 26rpx;
  color: #666666;
  margin-right: 8rpx;
}

.sort-icon {
  width: 24rpx;
  height: 24rpx;
}

.filter-panel {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
  padding: 20rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.filter-option {
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666666;
  background-color: #f5f5f5;
}

.filter-option.active {
  color: #ff6b35;
  background-color: #fff3ee;
  font-weight: bold;
}

.result-info {
  margin-bottom: 20rpx;
}

.result-count {
  font-size: 26rpx;
  color: #999999;
}

.recipe-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.recipe-card {
  display: flex;
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.recipe-image {
  width: 240rpx;
  height: 240rpx;
  flex-shrink: 0;
}

.recipe-content {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.recipe-header {
  margin-bottom: 12rpx;
}

.recipe-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 12rpx;
}

.recipe-tags {
  display: flex;
  gap: 12rpx;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.category-tag {
  color: #ff6b35;
  background-color: #fff3ee;
}

.difficulty-tag {
  color: #52c41a;
  background-color: #f6ffed;
}

.recipe-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.recipe-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.recipe-meta {
  display: flex;
  gap: 16rpx;
}

.meta-item {
  font-size: 22rpx;
  color: #999999;
}

.ingredients-text {
  font-size: 22rpx;
  color: #999999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #cccccc;
}