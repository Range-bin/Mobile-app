<view class="container">
  <view class="search-section">
    <view class="search-bar">
      <image class="search-icon" src="/images/search.png" mode="aspectFit"></image>
      <input 
        class="search-input" 
        placeholder="搜索菜谱、食材..." 
        value="{{searchKeyword}}" 
        bindinput="onSearchInput"
        bindconfirm="onSearch"
        confirm-type="search"
      />
      <image 
        wx:if="{{searchKeyword}}" 
        class="clear-icon" 
        src="/images/close.png" 
        mode="aspectFit"
        bindtap="clearSearch"
      ></image>
    </view>
    
    <view class="filter-row">
      <scroll-view class="category-scroll" scroll-x enable-flex>
        <view 
          class="category-tag {{currentCategory === item ? 'active' : ''}}"
          wx:for="{{categories}}"
          wx:key="*this"
          bindtap="selectCategory"
          data-category="{{item}}"
        >
          {{item}}
        </view>
      </scroll-view>
      
      <view class="sort-btn" bindtap="toggleFilter">
        <text class="sort-text">排序</text>
        <image class="sort-icon" src="/images/sort.png" mode="aspectFit"></image>
      </view>
    </view>

    <view class="filter-panel" wx:if="{{showFilter}}">
      <view 
        class="filter-option {{sortBy === 'default' ? 'active' : ''}}"
        bindtap="sortRecipes"
        data-type="default"
      >默认排序</view>
      <view 
        class="filter-option {{sortBy === 'likes' ? 'active' : ''}}"
        bindtap="sortRecipes"
        data-type="likes"
      >最多点赞</view>
      <view 
        class="filter-option {{sortBy === 'time' ? 'active' : ''}}"
        bindtap="sortRecipes"
        data-type="time"
      >制作时间</view>
      <view 
        class="filter-option {{sortBy === 'difficulty' ? 'active' : ''}}"
        bindtap="sortRecipes"
        data-type="difficulty"
      >难度排序</view>
    </view>
  </view>

  <view class="result-info">
    <text class="result-count">共找到 {{filteredRecipes.length}} 道菜谱</text>
  </view>

  <view class="recipe-list" wx:if="{{filteredRecipes.length > 0}}">
    <view 
      class="recipe-card"
      wx:for="{{filteredRecipes}}"
      wx:key="id"
      bindtap="goToDetail"
      data-id="{{item.id}}"
    >
      <image class="recipe-image" src="{{item.image}}" mode="aspectFill"></image>
      <view class="recipe-content">
        <view class="recipe-header">
          <text class="recipe-title">{{item.title}}</text>
          <view class="recipe-tags">
            <text class="tag category-tag">{{item.category}}</text>
            <text class="tag difficulty-tag">{{item.difficulty}}</text>
          </view>
        </view>
        
        <text class="recipe-desc text-ellipsis">{{item.description}}</text>
        
        <view class="recipe-footer">
          <view class="recipe-meta">
            <text class="meta-item">⏱ {{item.time}}</text>
            <text class="meta-item">❤️ {{item.likes}}</text>
          </view>
          <view class="recipe-ingredients-preview">
            <text class="ingredients-text">食材: {{item.ingredients[0]}} 等{{item.length}}种</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{filteredRecipes.length === 0}}">
    <image class="empty-icon" src="/images/empty.png" mode="aspectFit"></image>
    <text class="empty-text">暂无相关菜谱</text>
    <text class="empty-hint">试试其他关键词吧~</text>
  </view>
</view>