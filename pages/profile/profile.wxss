.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.profile-header {
  background: linear-gradient(135deg, #ff6b35 0%, #ff8f5a 100%);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.3);
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.user-detail {
  flex: 1;
  margin-left: 24rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.user-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.arrow-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.7;
}

.stats-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 24rpx 0;
  backdrop-filter: blur(10rpx);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.stat-divider {
  width: 1rpx;
  height: 50rpx;
  background-color: rgba(255, 255, 255, 0.4);
}

.menu-section,
.about-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
  padding-left: 12rpx;
  border-left: 6rpx solid #ff6b35;
}

.menu-list,
.about-list {
  display: flex;
  flex-direction: column;
}

.menu-item,
.about-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child,
.about-item:last-child {
  border-bottom: none;
}

.menu-icon-wrapper,
.about-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  background-color: #fff3ee;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.about-icon-wrapper {
  background-color: #f6ffed;
}

.menu-icon,
.about-icon {
  font-size: 36rpx;
}

.menu-content,
.about-content {
  flex: 1;
}

.menu-title,
.about-title {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  display: block;
  margin-bottom: 6rpx;
}

.menu-desc,
.about-desc {
  font-size: 24rpx;
  color: #999999;
}

.menu-arrow,
.about-arrow {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.4;
}

.action-section {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  margin: 0;
}

.action-btn::after {
  border: none;
}

.cache-btn {
  background-color: #fff2f0;
  color: #ff4d4f;
}

.share-btn {
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
  color: #ffffff;
}

.btn-text {
  font-size: 28rpx;
}

.footer {
  text-align: center;
  padding: 30rpx 0;
}

.footer-text {
  font-size: 26rpx;
  color: #999999;
  display: block;
  margin-bottom: 8rpx;
}

.footer-copyright {
  font-size: 22rpx;
  color: #cccccc;
}