.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.header-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.favorites-count {
  font-size: 28rpx;
  color: #666666;
}

.clear-btn {
  padding: 12rpx 24rpx;
  background-color: #fff2f0;
  border-radius: 30rpx;
}

.clear-text {
  font-size: 26rpx;
  color: #ff4d4f;
}

.favorites-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.favorite-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.card-content {
  display: flex;
  padding: 20rpx;
}

.recipe-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.recipe-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.recipe-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.recipe-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.meta-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.meta-tag.category {
  color: #ff6b35;
  background-color: #fff3ee;
}

.meta-tag.difficulty {
  color: #52c41a;
  background-color: #f6ffed;
}

.meta-time {
  font-size: 22rpx;
  color: #999999;
}

.recipe-desc {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.4;
}

.card-actions {
  display: flex;
  gap: 20rpx;
  padding: 16rpx 20rpx;
  border-top: 1rpx solid #f5f5f5;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  border-radius: 30rpx;
}

.btn-text {
  font-size: 26rpx;
  font-weight: bold;
}

.delete-btn {
  background-color: #fff2f0;
}

.delete-btn .btn-text {
  color: #ff4d4f;
}

.view-btn {
  background-color: #fff3ee;
}

.view-btn .btn-text {
  color: #ff6b35;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 280rpx;
  height: 280rpx;
  margin-bottom: 40rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 34rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 40rpx;
}

.go-btn {
  width: 400rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8f5a 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
  margin: 0;
}

.go-btn::after {
  border: none;
}