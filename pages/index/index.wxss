.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.search-bar {
  margin-bottom: 30rpx;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 40rpx;
  padding: 16rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.section-subtitle {
  font-size: 26rpx;
  color: #999999;
  margin-left: 12rpx;
}

.more-link {
  font-size: 26rpx;
  color: #ff6b35;
}

.recommend-section {
  margin-bottom: 40rpx;
}

.recommend-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 53, 0.15);
}

.recommend-image {
  width: 100%;
  height: 400rpx;
  display: block;
}

.recommend-info {
  padding: 28rpx;
}

.recommend-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 12rpx;
}

.recommend-desc {
  font-size: 26rpx;
  color: #666666;
  display: block;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.recommend-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #999999;
}

.categories-section {
  margin-bottom: 40rpx;
}

.categories-scroll {
  white-space: nowrap;
}

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 160rpx;
  height: 180rpx;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8f5a 100%);
  border-radius: 20rpx;
  margin-right: 20rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.2);
}

.category-name {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.category-count {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.hot-section {
  margin-bottom: 40rpx;
}

.hot-scroll {
  white-space: nowrap;
}

.hot-card {
  display: inline-block;
  width: 280rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-right: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.hot-image {
  width: 280rpx;
  height: 220rpx;
  display: block;
}

.hot-info {
  padding: 20rpx;
}

.hot-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 12rpx;
}

.hot-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hot-time,
.hot-likes {
  font-size: 22rpx;
  color: #999999;
}